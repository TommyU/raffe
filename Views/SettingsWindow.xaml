<Window x:Class="Raffe.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="抽奖设置" Height="580" Width="780"
        WindowStartupLocation="CenterOwner"
        Background="#1A0800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="抽奖设置" FontSize="22" Foreground="#FFD700" FontWeight="Bold" Margin="0,0,0,15"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    Foreground="White" FontSize="14">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="#FFEECC"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Padding="15,8" Margin="2,0"
                                        Background="#2A1000" CornerRadius="6"
                                        BorderBrush="#55FFD700" BorderThickness="1">
                                    <ContentPresenter ContentSource="Header"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#88FF5500"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#FFD700"/>
                                        <Setter Property="Foreground" Value="#FFD700"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style TargetType="DataGrid">
                    <Setter Property="Background" Value="#1A0800"/>
                    <Setter Property="Foreground" Value="#FFEECC"/>
                    <Setter Property="BorderBrush" Value="#55FFD700"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="RowBackground" Value="#1A0800"/>
                    <Setter Property="AlternatingRowBackground" Value="#2A1200"/>
                    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                    <Setter Property="HeadersVisibility" Value="Column"/>
                    <Setter Property="HorizontalGridLinesBrush" Value="#33FFD700"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>

                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#3D1800"/>
                    <Setter Property="Foreground" Value="#FFD700"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="BorderBrush" Value="#66FFD700"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                </Style>

                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#FFEECC"/>
                    <Setter Property="Padding" Value="4,0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#66FF6600"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#33FF6600"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="TextBox">
                    <Setter Property="Background" Value="#2A1200"/>
                    <Setter Property="Foreground" Value="#FFEECC"/>
                    <Setter Property="BorderBrush" Value="#66FFD700"/>
                    <Setter Property="CaretBrush" Value="#FFD700"/>
                    <Setter Property="SelectionBrush" Value="#66FF8800"/>
                    <Setter Property="Padding" Value="8,7"/>
                    <Setter Property="FontSize" Value="14"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="参与者管理">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="＋ 添加" Command="{Binding AddParticipantCommand}" Padding="14,6"
                                Background="#44FF6600" Foreground="#FFD700" BorderBrush="#88FFD700" BorderThickness="1" Cursor="Hand"/>
                        <Button Content="⬆ Excel导入" Command="{Binding LoadFromExcelCommand}" Padding="14,6" Margin="10,0,0,0"
                                Background="#44FF6600" Foreground="#FFD700" BorderBrush="#88FFD700" BorderThickness="1" Cursor="Hand"/>
                        <Button Content="⬇ 下载模板" Command="{Binding SaveTemplateCommand}" Padding="14,6" Margin="10,0,0,0"
                                Background="#44FF6600" Foreground="#FFD700" BorderBrush="#88FFD700" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Participants}"
                              AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="部门" Binding="{Binding Department, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="删除" Command="{Binding DataContext.RemoveParticipantCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" Padding="5,2"
                                                Background="Transparent" Foreground="#FF7070" BorderThickness="0" Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="奖项设置">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="奖项从低到高排序，可自定义名称、总人数、每批人数" Foreground="#FFCC77" FontSize="13" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding PrizeLevels}"
                              AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="级别名称" Binding="{Binding LevelName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="总人数" Binding="{Binding MaxWinners, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            <DataGridTextColumn Header="批次数" Binding="{Binding BatchCount, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="抽奖控制">
                <StackPanel Margin="20" VerticalAlignment="Top">
                    <Button Content="📤  导出中奖名单" Command="{Binding ExportResultsCommand}"
                            Padding="20,12" FontSize="16" Cursor="Hand"
                            Background="#44FF8800" Foreground="#FFD700"
                            BorderBrush="#88FFD700" BorderThickness="1"/>
                    <TextBlock Text="导出所有获奖人员（部门、姓名、奖项）到 Excel 文件" Foreground="#FFCC77" Margin="0,8,0,20" FontSize="13"/>

                    <Button Content="🔄  重新开始抽奖" Command="{Binding RestartLotteryCommand}"
                            Padding="20,12" FontSize="16" Cursor="Hand"
                            Background="#44FF2200" Foreground="#FFD700"
                            BorderBrush="#88FFD700" BorderThickness="1"/>
                    <TextBlock Text="清空所有抽奖结果，所有人可重新参与抽奖" Foreground="#FFCC77" Margin="0,8,0,0" FontSize="13"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="音乐设置">
                <StackPanel Margin="20" VerticalAlignment="Top">

                    <!-- 音量 -->
                    <TextBlock Text="音量" Foreground="#FFD700" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Slider Minimum="0" Maximum="1" Value="{Binding MusicVolume, UpdateSourceTrigger=PropertyChanged}"
                                Width="260" VerticalAlignment="Center"
                                Foreground="#FFD700"/>
                        <TextBlock Text="{Binding MusicVolume, StringFormat={}{0:P0}}"
                                   Foreground="#FFEECC" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 三类音乐行 -->
                    <TextBlock Text="默认背景音乐" Foreground="#FFD700" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding DefaultMusicPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="浏览" Command="{Binding BrowseDefaultMusicCommand}"
                                Padding="14,6" Margin="8,0,0,0" Cursor="Hand"
                                Background="#44FF6600" Foreground="#FFD700" BorderBrush="#66FFD700" BorderThickness="1"/>
                        <Button Grid.Column="2" Content="清除" Padding="14,6" Margin="6,0,0,0" Cursor="Hand"
                                Background="#22FFFFFF" Foreground="#FFCC77" BorderBrush="#33FFFFFF" BorderThickness="1"
                                Click="ClearDefaultMusic"/>
                    </Grid>

                    <TextBlock Text="抽奖旋转音乐" Foreground="#FFD700" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SpinningMusicPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="浏览" Command="{Binding BrowseSpinningMusicCommand}"
                                Padding="14,6" Margin="8,0,0,0" Cursor="Hand"
                                Background="#44FF6600" Foreground="#FFD700" BorderBrush="#66FFD700" BorderThickness="1"/>
                        <Button Grid.Column="2" Content="清除" Padding="14,6" Margin="6,0,0,0" Cursor="Hand"
                                Background="#22FFFFFF" Foreground="#FFCC77" BorderBrush="#33FFFFFF" BorderThickness="1"
                                Click="ClearSpinningMusic"/>
                    </Grid>

                    <TextBlock Text="中奖庆祝音乐" Foreground="#FFD700" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding WinnerMusicPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="浏览" Command="{Binding BrowseWinnerMusicCommand}"
                                Padding="14,6" Margin="8,0,0,0" Cursor="Hand"
                                Background="#44FF6600" Foreground="#FFD700" BorderBrush="#66FFD700" BorderThickness="1"/>
                        <Button Grid.Column="2" Content="清除" Padding="14,6" Margin="6,0,0,0" Cursor="Hand"
                                Background="#22FFFFFF" Foreground="#FFCC77" BorderBrush="#33FFFFFF" BorderThickness="1"
                                Click="ClearWinnerMusic"/>
                    </Grid>

                    <TextBlock Foreground="#FFAA44" FontSize="12" TextWrapping="Wrap"
                               Text="支持 MP3 / WAV / WMA / AAC 格式，留空则该场景静音。点击[确定]后生效。"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="基本设置">
                <StackPanel Margin="20" VerticalAlignment="Top">
                    <TextBlock Text="公司名称" Foreground="#FFCC77" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>
                    <TextBlock Text="年份" Foreground="#FFCC77" Margin="0,16,0,6"/>
                    <TextBox Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="确  定" Click="OnOkClick" Padding="25,8"
                    Background="#55FF6600" Foreground="#FFD700"
                    BorderBrush="#88FFD700" BorderThickness="1" Cursor="Hand"/>
            <Button Content="取  消" Click="OnCancelClick" Padding="25,8" Margin="10,0,0,0"
                    Background="#22FFFFFF" Foreground="#CCCCCC"
                    BorderBrush="#44FFFFFF" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
