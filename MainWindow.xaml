<Window x:Class="Raffe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Raffe.Controls"
        Title="年会抽奖" Height="800" Width="1200"
        WindowState="Maximized"
        Background="#1A0800" ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <!-- 标题发光效果 -->
        <DropShadowEffect x:Key="TitleGlow" Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
        <DropShadowEffect x:Key="TextGlow" Color="#FF6600" BlurRadius="15" ShadowDepth="0" Opacity="0.9"/>

        <!-- 设置按钮样式 -->
        <Style x:Key="SettingsBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF88"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 背景渐变 -->
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.3" RadiusX="0.8" RadiusY="0.7">
                <GradientStop Color="#3D0C00" Offset="0"/>
                <GradientStop Color="#1A0800" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题区：双击切换全屏 -->
        <Border Grid.Row="0" Padding="30,20"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#55000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <!-- 装饰线 -->
                <Border VerticalAlignment="Bottom" Height="1" Margin="0,0,0,-1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFD700" Offset="0"/>
                            <GradientStop Color="#FFFFD700" Offset="0.5"/>
                            <GradientStop Color="#00FFD700" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="46" FontWeight="Bold"
                               Foreground="#FFD700"
                               Effect="{StaticResource TitleGlow}">
                        <Run Text="{Binding CompanyName, Mode=OneWay}"/>
                        <Run Text="{Binding Year, Mode=OneWay}"/>
                        <Run Text="年度年会"/>
                    </TextBlock>
                </StackPanel>

                <Button Style="{StaticResource SettingsBtn}"
                        Content="⚙  设置" Command="{Binding OpenSettingsCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 主区域 -->
        <Grid Grid.Row="1" Margin="20,10,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 旋转球区域：无边框，直接在主背景上浮动 -->
            <Grid Grid.Row="0">
                    <!-- 旋转名字（仅非空闲时显示） -->
                    <controls:LotteryCarousel x:Name="Carousel"
                        Visibility="{Binding IsNotIdle, Converter={StaticResource BoolToVis}}"
                        Participants="{Binding DisplayParticipants}"
                        IsSpinning="{Binding IsSpinning}"
                        BatchSize="{Binding CurrentBatchSize}"
                        StoppedParticipants="{Binding StoppedParticipants, Mode=OneWayToSource}"/>

                    <!-- 空闲待机图片轮播（覆盖在旋转区域上方） -->
                    <controls:IdleSlideshow
                        Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}"
                        ImagePaths="{Binding SlideshowImagePaths}"
                        IsActive="{Binding IsIdle}"
                        IntervalSeconds="{Binding SlideshowIntervalSeconds}"/>

                    <!-- 倒计时覆盖层 -->
                    <Border Visibility="{Binding IsCountingDown, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Border.Background>
                            <RadialGradientBrush Center="0.5,0.3" RadiusX="0.8" RadiusY="0.7">
                                <GradientStop Color="#3D0C00" Offset="0"/>
                                <GradientStop Color="#1A0800" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                        <!-- 圆圈 + 数字 -->
                        <Border Width="300" Height="300" CornerRadius="150"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                BorderBrush="#BBFFD700" BorderThickness="5">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#55FF8800" Offset="0"/>
                                    <GradientStop Color="#22FF4400" Offset="1"/>
                                </RadialGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="40" ShadowDepth="0" Opacity="0.55"/>
                            </Border.Effect>
                            <TextBlock Text="{Binding CountdownText}"
                                       FontSize="190" FontWeight="Bold"
                                       Foreground="#FFD700"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Effect="{StaticResource TitleGlow}"/>
                        </Border>
                    </Border>

                    <!-- 中奖弹出层 -->
                    <Border Visibility="{Binding ShowWinners, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            CornerRadius="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#EE1A0000" Offset="0"/>
                                <GradientStop Color="#EE2D0A00" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- 中奖标题 -->
                            <TextBlock Text="🎊  恭喜获奖  🎊"
                                       FontSize="38" FontWeight="Bold"
                                       Foreground="#FFD700"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"
                                       Effect="{StaticResource TitleGlow}"/>

                            <!-- 分隔线 -->
                            <Border Height="2" Width="400" Margin="0,5,0,20">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00FFD700" Offset="0"/>
                                        <GradientStop Color="#FFFFD700" Offset="0.5"/>
                                        <GradientStop Color="#00FFD700" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- 奖项名称（本次刚抽完的奖项）-->
                            <TextBlock Text="{Binding LastWonPrizeName}" Foreground="#FFAA00"
                                       FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                            <!-- 获奖名单：始终一排横排，人多时可水平滚动 -->
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          HorizontalAlignment="Center" MaxWidth="1100">
                                <ItemsControl ItemsSource="{Binding Winners}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="10,6" Padding="22,14" CornerRadius="14"
                                                    BorderBrush="#88FFD700" BorderThickness="1.5"
                                                    MinWidth="140">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#55FF6600" Offset="0"/>
                                                        <GradientStop Color="#33FF3300" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#FFD700" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                                                </Border.Effect>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="36" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               Effect="{StaticResource TextGlow}"/>
                                                    <TextBlock Text="{Binding Department}"
                                                               FontSize="15" Foreground="#FFCC77"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
            </Grid>

            <!-- 底部状态栏 -->
            <Border Grid.Row="1" Margin="0,18,0,18" HorizontalAlignment="Center"
                    Padding="30,10" CornerRadius="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#44FF6600" Offset="0"/>
                        <GradientStop Color="#22FF3300" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#88FFD700" Offset="0"/>
                        <GradientStop Color="#33FFD700" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>1</Border.BorderThickness>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding CurrentPrizeDisplay}"
                               Foreground="#FFD700" FontSize="17" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="   ·   " Foreground="#88FFD700" FontSize="17" VerticalAlignment="Center"/>
                    <TextBlock Text="按 空格键 开始 / 停止抽奖"
                               Foreground="#FFCC77" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════ 抽奖汇总结果页 ══════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Visibility="{Binding ShowResults, Converter={StaticResource BoolToVis}}">
            <Grid.Background>
                <RadialGradientBrush Center="0.5,0.3" RadiusX="0.9" RadiusY="0.8">
                    <GradientStop Color="#3D0C00" Offset="0"/>
                    <GradientStop Color="#0D0200" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── 顶部标题区 + 右上角返回按钮 ── -->
            <Grid Grid.Row="0" Margin="24,28,24,16">
                <!-- 标题居中 -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🎊  恭喜所有获奖人员  🎊"
                               FontSize="40" FontWeight="Bold" Foreground="#FFD700"
                               HorizontalAlignment="Center"
                               Effect="{StaticResource TitleGlow}"/>
                    <TextBlock HorizontalAlignment="Center" Margin="0,6,0,0"
                               FontSize="16" Foreground="#FFCC77">
                        <Run Text="{Binding CompanyName, Mode=OneWay}"/>
                        <Run Text="{Binding Year, Mode=OneWay}"/>
                        <Run Text="年度年会  圆满完成"/>
                    </TextBlock>
                    <Border Height="2" Width="460" Margin="0,14,0,0" HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#00FFD700" Offset="0"/>
                                <GradientStop Color="#FFFFD700" Offset="0.5"/>
                                <GradientStop Color="#00FFD700" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- 右上角返回图标按钮 -->
                <Button Command="{Binding CloseResultsCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="44" Height="44" Cursor="Hand" ToolTip="返回抽奖">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Width="44" Height="44" CornerRadius="22"
                                    BorderBrush="#66FFD700" BorderThickness="1.5">
                                <Border.Background>
                                    <SolidColorBrush Color="#44FF5500"/>
                                </Border.Background>
                                <TextBlock Text="←" FontSize="20" FontWeight="Bold"
                                           Foreground="#FFD700"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background">
                                        <Setter.Value><SolidColorBrush Color="#77FF6600"/></Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Bd" Property="BorderBrush">
                                        <Setter.Value><SolidColorBrush Color="#FFD700"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ── 奖项列式展示：每个奖项一列，获奖人竖排 ── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,0,20,24">
                <ItemsControl ItemsSource="{Binding ResultGroups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- 所有奖项并排，等宽列 -->
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 单列：奖项名 + 竖排获奖人 -->
                            <Border Margin="8,0" CornerRadius="18" BorderThickness="1">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#88FFD700" Offset="0"/>
                                        <GradientStop Color="#33FF8800" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#55200800" Offset="0"/>
                                        <GradientStop Color="#33100400" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <!-- 奖项标题栏 -->
                                    <Border CornerRadius="17,17,0,0" Padding="0,14,0,14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#99FF5500" Offset="0"/>
                                                <GradientStop Color="#99FF8800" Offset="0.5"/>
                                                <GradientStop Color="#99FF5500" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding PrizeName}"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="#FFD700"
                                                   HorizontalAlignment="Center"
                                                   Effect="{StaticResource TitleGlow}"/>
                                    </Border>

                                    <!-- 细分隔线 -->
                                    <Border Height="1" Margin="12,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#00FFD700" Offset="0"/>
                                                <GradientStop Color="#88FFD700" Offset="0.5"/>
                                                <GradientStop Color="#00FFD700" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- 获奖人列表（竖排） -->
                                    <ItemsControl ItemsSource="{Binding Winners}" Margin="10,8,10,10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,4" Padding="12,9" CornerRadius="10"
                                                        BorderBrush="#44FFD700" BorderThickness="1">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#33FF4400" Offset="0"/>
                                                            <GradientStop Color="#22FF2200" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="18" FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Department}"
                                                                   FontSize="12" Foreground="#FFAA55"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
